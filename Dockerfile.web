# Етап 1: Збірка (Build)
FROM cirrusci/flutter:stable AS build

WORKDIR /app
COPY frontend/ .

RUN flutter pub get
RUN flutter build web --release --web-renderer canvaskit

# Етап 2: Хостинг (Serve)
FROM nginx:alpine

# Копіюємо файли збірки до Nginx
COPY --from=build /app/build/web /usr/share/nginx/html

# Додаємо конфігурацію для коректної роботи маршрутизації Flutter (SPA)
RUN echo "server { \
    listen 80; \
    location / { \
        root /usr/share/nginx/html; \
        index index.html; \
        try_files \$uri \$uri/ /index.html; \
    } \
}" > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
